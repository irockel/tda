{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":separateMajorReleases"
  ],
  "dependencyDashboard": true,
  "packageRules": [
    {
      "description": "Pin digests for custom GitHub Actions, but not official ones",
      "matchManagers": ["github-actions"],
      "excludePackagePatterns": ["^actions/"],
      "pinDigests": true
    },
    {
      "description": "Group minor und patch Updates",
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "non-major dependencies",
      "schedule": ["before 8am on monday"]
    },
    {
      "description": "Major Updates in isolated PRs",
      "matchUpdateTypes": ["major"],
      "labels": ["major-update", "manual-review"]
    },
    {
      "description": "Keep NetBeans at RELEASE220 as newer versions require JDK 21",
      "matchPackageNames": ["org.netbeans.api:*", "org.netbeans.modules:*", "org.netbeans.external:*"],
      "matchPackagePrefixes": ["org.netbeans"],
      "allowedVersions": "(,RELEASE230)"
    },
    {
      "description": "Restrict netbeans.version property",
      "matchDepNames": ["netbeans.version"],
      "allowedVersions": "(,RELEASE230)"
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "assignees": ["irockel"]
  },
  "timezone": "Europe/Berlin"
}
